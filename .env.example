# PredictaCore Titán — Variables de entorno
# Copiar a .env local (nunca commitear .env con valores reales)

# ─── Servidor ───────────────────────────────────────────────────────────────
PORT=8080

# ─── PostgreSQL (Railway Postgres plugin) ───────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/railway

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Opcional: Price IDs fijos desde Stripe Dashboard (recomendado producción)
STRIPE_PRICE_TITAN=price_...
STRIPE_PRICE_SUBSCRIPTION=price_...
# Fase 3 — Stripe Connect (payouts automáticos a afiliados)
STRIPE_CONNECT_CLIENT_ID=ca_...

# ─── Playground (pruebas internas) ──────────────────────────────────────────
# Protege /playground — genera una clave larga aleatoria
API_KEY=tu_clave_secreta_playground

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── Vertex AI / Gemini (JSON completo del service account) ─────────────────
GOOGLE_CREDS={"type":"service_account","project_id":"...","private_key":"..."}

# ─── Opcionales (sin uso en server.js aún) ──────────────────────────────────
# JINA_API_KEY=
# XAI_API_KEY=
