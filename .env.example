# PredictaCore Titán — Variables de entorno
# Copiar a .env local (nunca commitear .env con valores reales)

# ─── Servidor ───────────────────────────────────────────────────────────────
PORT=8080
# URL pública para return_url del portal Stripe y enlaces en correos
PUBLIC_BASE_URL=https://predictacore.ai

# ─── PostgreSQL (Railway Postgres plugin) ───────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/railway

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Standard secret (sk_test_/sk_live_) or restricted key (rk_test_/rk_live_) with Checkout + Prices permissions
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Opcional: Price IDs fijos desde Stripe Dashboard (recomendado producción)
# Live: Predictacore Titan USD $199 + Predictacore monthly update $25/mo
STRIPE_PRICE_TITAN=price_...
STRIPE_PRICE_SUBSCRIPTION=price_...
# Bank statement suffix for PredictaCore charges (max 22 chars)
STRIPE_STATEMENT_DESCRIPTOR=PREDICTACORE
# Optional: Stripe Customer Portal config (PredictaCore-only branding in Dashboard)
STRIPE_PORTAL_CONFIG=bpc_...
# Fase 3 — Stripe Connect (payouts automáticos a afiliados)
STRIPE_CONNECT_CLIENT_ID=ca_...

# ─── Playground (pruebas internas) ──────────────────────────────────────────
# Protege /playground — genera una clave larga aleatoria
API_KEY=tu_clave_secreta_playground
# Clave para /titan-interno (reporte Titán sin cobro)
TITAN_INTERNAL_KEY=12345

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
# Remitente de PDFs y activación Titán (dominio debe estar verificado en Resend)
# RESEND_FROM=PredictaCore <audit@predictacore.ai>
# SUPPORT_EMAIL=audit@predictacore.ai

# ─── Vertex AI / Gemini (JSON completo del service account) ─────────────────
GOOGLE_CREDS={"type":"service_account","project_id":"...","private_key":"..."}

# ─── Opcionales (sin uso en server.js aún) ──────────────────────────────────
# JINA_API_KEY=
# XAI_API_KEY=
